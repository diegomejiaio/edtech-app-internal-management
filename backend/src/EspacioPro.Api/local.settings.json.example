{
  "IsEncrypted": false,
  "Values": {
    "FUNCTIONS_WORKER_RUNTIME": "dotnet-isolated",

    "// Storage": "AzureWebJobsStorage is intentionally OMITTED. We only have HTTP triggers; no blob/queue/table/durable functions. Setting it would force the runtime to validate a storage connection (Azurite locally, real account in cloud) for nothing. In Azure, the deployed FunctionApp does set it via Bicep for diagnostics + scale.",

    "// Cosmos auth": "Pick ONE of the two modes below. Mode A is recommended; Mode B is local-dev convenience only.",

    "// Mode A — Managed Identity / az login (production-equivalent, no secrets)": "Set ENDPOINT only and run `az login` once. Your account needs the 'Cosmos DB Built-in Data Contributor' role.",
    "COSMOS_ACCOUNT_ENDPOINT": "https://<your-cosmos-account>.documents.azure.com:443/",
    "COSMOS_DATABASE_NAME": "espaciopro-dev",

    "// Mode B — Connection string (no Azure RBAC needed yet)": "Uncomment and paste the dev-account primary connection string. Do NOT commit. Do NOT use in production.",
    "// COSMOS_CONNECTION_STRING": "AccountEndpoint=https://<your-cosmos-account>.documents.azure.com:443/;AccountKey=<key>;",

    "CLERK_JWKS_URL": "https://<your-clerk-instance>.clerk.accounts.dev/.well-known/jwks.json",
    "CLERK_ISSUER": "https://<your-clerk-instance>.clerk.accounts.dev",
    "CORS_ORIGINS": "http://localhost:3000",

    "// Dev auth bypass": "OPTIONAL local-only escape hatch. Requires BOTH flags below set. Injects a synthetic admin principal so endpoints with [RequireRole] can be hit without a Clerk JWT. The middleware logs a WARNING on every request when active. Both flags must be unset/false in production.",
    "AZURE_FUNCTIONS_ENVIRONMENT": "Development",
    "// DEV_AUTH_BYPASS": "true"
  },
  "Host": {
    "CORS": "http://localhost:3000",
    "CORSCredentials": true
  }
}
