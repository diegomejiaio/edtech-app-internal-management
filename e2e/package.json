{
  "name": "espacio-pro-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "E2E regression tests for Espacio Pro v1",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:safe": "playwright test --grep-invert @write-heavy",
    "test:mocked": "playwright test --grep @mocked",
    "test:write": "PW_WORKERS=1 playwright test --grep @write-heavy",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^25.9.1",
    "dotenv": "^16.4.7",
    "typescript": "^6.0.3"
  }
}
