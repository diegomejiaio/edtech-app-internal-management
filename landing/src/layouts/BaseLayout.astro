---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  ogType?: "website" | "article";
  ogImage?: string;
  ogImageAlt?: string;
  articlePublishedTime?: Date;
  articleModifiedTime?: Date;
  articleAuthor?: string;
  articleTags?: string[];
  structuredData?: Record<string, unknown>[];
}

const {
  title,
  description = "Clearbook centraliza notificaciones SUNAT, comprobantes electrónicos y declaraciones de todos tus clientes en una sola plataforma. Hecha para estudios contables en Perú.",
  noindex = false,
  ogType = "website",
  ogImage = "/og-image.png",
  ogImageAlt = "Clearbook — Plataforma de gestión contable para estudios en Perú",
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
  articleTags = [],
  structuredData = [],
} = Astro.props;

// Avoid duplicating the brand: only append "| Clearbook" when the title doesn't already contain it.
const pageTitle = /clearbook/i.test(title) ? title : `${title} | Clearbook`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
const ogImageType = ogImageURL.pathname.endsWith(".jpg") || ogImageURL.pathname.endsWith(".jpeg")
  ? "image/jpeg"
  : "image/png";
---

<!doctype html>
<html lang="es-PE" class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0b0b0f" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="google-site-verification" content="HMFWhneGc_T-RwO9Xry-q7aIbNXbcrmKUCU_dVVsFCU" />
    {noindex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="preload" href="/fonts/nunito-sans-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="es-PE" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="alternate" type="application/rss+xml" title="Clearbook Blog" href="/rss.xml" />
    <meta name="description" content={description} />
    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:type" content={ogImageType} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content="es_PE" />
    <meta property="og:site_name" content="Clearbook" />
    {ogType === "article" && articlePublishedTime ? <meta property="article:published_time" content={articlePublishedTime.toISOString()} /> : null}
    {ogType === "article" && articleModifiedTime ? <meta property="article:modified_time" content={articleModifiedTime.toISOString()} /> : null}
    {ogType === "article" && articleAuthor ? <meta property="article:author" content={articleAuthor} /> : null}
    {ogType === "article" && articleTags.map((tag) => <meta property="article:tag" content={tag} />)}
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <title>{pageTitle}</title>
    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Clearbook",
      "url": "https://clear-book.com",
      "logo": "https://clear-book.com/logo-dark.svg",
      "description": description,
      "areaServed": { "@type": "Country", "name": "Peru" },
      "inLanguage": "es-PE",
      "sameAs": []
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Clearbook",
      "url": "https://clear-book.com",
      "inLanguage": "es-PE"
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Clearbook",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": description,
      "url": "https://clear-book.com",
      "inLanguage": "es-PE"
    })} />
    {structuredData.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)} />)}
    <!-- Inline theme script to prevent FOUC -->
    <script is:inline>
      (function() {
        // Dark mode is the default. Only respect 'light' if user explicitly chose it.
        const stored = localStorage.getItem('theme');
        const theme = stored === 'light' ? 'light' : 'dark';
        document.documentElement.classList.toggle('dark', theme === 'dark');
        document.documentElement.classList.toggle('light', theme !== 'dark');
      })();
    </script>
    <!-- React to live changes of prefers-reduced-motion: animations are built once at init,
         so the simplest correct behavior is to reload when the OS preference changes. -->
    <script is:inline>
      (function() {
        if (!window.matchMedia) return;
        var mql = window.matchMedia("(prefers-reduced-motion: reduce)");
        var handler = function() {
          // Reload to rebuild every animation in its new mode.
          window.location.reload();
        };
        if (typeof mql.addEventListener === "function") mql.addEventListener("change", handler);
        else if (typeof mql.addListener === "function") mql.addListener(handler);
      })();
    </script>
    <!-- Google Tag Manager — deferred until idle to avoid blocking LCP.
         TODO: gate behind cookie consent banner per Ley 29733 (Peru). -->
    <script is:inline>
      (function() {
        function loadGTM() {
          var w = window, d = document, l = "dataLayer", i = "GTM-N9TJGNSX";
          w[l] = w[l] || [];
          w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
          var f = d.getElementsByTagName("script")[0];
          var j = d.createElement("script");
          j.async = true;
          j.src = "https://www.googletagmanager.com/gtm.js?id=" + i;
          f.parentNode.insertBefore(j, f);
        }
        if ("requestIdleCallback" in window) {
          requestIdleCallback(loadGTM, { timeout: 3000 });
        } else {
          setTimeout(loadGTM, 2000);
        }
      })();
    </script>
    <!-- End Google Tag Manager -->
    <!-- Microsoft Clarity — same project as the SaaS app (front/src/app/layout.tsx) so the
         visitor → signup → activation journey lives in one Clarity dashboard. Deferred until
         idle to avoid blocking LCP. Project ID: w34sfzcbbo.
         TODO: gate behind cookie consent banner per Ley 29733 (Peru) — session replay records
         interactions, more sensitive than GA4 page views. -->
    <script is:inline>
      (function() {
        function loadClarity() {
          (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
          })(window,document,"clarity","script","w34sfzcbbo");
        }
        if ("requestIdleCallback" in window) {
          requestIdleCallback(loadClarity, { timeout: 3000 });
        } else {
          setTimeout(loadClarity, 2000);
        }
      })();
    </script>
    <!-- End Microsoft Clarity -->
  </head>
  <body class="min-h-screen font-sans antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-N9TJGNSX"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <!-- Skip navigation link (IV-004) -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-100 focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-foreground">Saltar al contenido</a>
    <slot />
  </body>
</html>
