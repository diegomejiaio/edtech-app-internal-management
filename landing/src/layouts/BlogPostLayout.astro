---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WaitlistModal from "../components/WaitlistModal.astro";

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  author: string;
  tags: string[];
  cover?: string;
  coverAlt?: string;
}

const { title, description, publishedAt, updatedAt, author, tags, cover, coverAlt } =
  Astro.props;

const dateFormatter = new Intl.DateTimeFormat("es-PE", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const blogPostingStructuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": publishedAt.toISOString(),
  "dateModified": (updatedAt ?? publishedAt).toISOString(),
  "author": { "@type": "Organization", "name": author },
  "publisher": {
    "@type": "Organization",
    "name": "Clearbook",
    "logo": { "@type": "ImageObject", "url": new URL("/logo-dark.svg", Astro.site).toString() },
  },
  "image": new URL(cover ?? "/og-image.png", Astro.site).toString(),
  "mainEntityOfPage": new URL(Astro.url.pathname, Astro.site).toString(),
  "inLanguage": "es-PE",
  "keywords": tags.join(", "),
};
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage={cover ?? "/og-image.png"}
  ogImageAlt={coverAlt ?? title}
  articlePublishedTime={publishedAt}
  articleModifiedTime={updatedAt ?? publishedAt}
  articleAuthor={author}
  articleTags={tags}
  structuredData={[blogPostingStructuredData]}
>
  <Header />

  <main class="container mx-auto max-w-3xl px-6 py-16 md:py-24">
    <article>
      <header class="mb-10 border-b border-border/60 pb-10">
        <div class="mb-6 flex flex-wrap items-center gap-3 text-xs text-muted-foreground">
          <a href="/blog/" class="hover:text-foreground">Blog</a>
          <span aria-hidden="true">›</span>
          <time datetime={publishedAt.toISOString()}>
            {dateFormatter.format(publishedAt)}
          </time>
          <span aria-hidden="true">·</span>
          <span>{author}</span>
        </div>

        <h1 class="text-balance text-4xl font-bold leading-tight text-foreground md:text-5xl">
          {title}
        </h1>

        <p class="mt-4 text-lg text-muted-foreground">{description}</p>

        {tags.length > 0 && (
          <ul class="mt-6 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <li class="rounded-full border border-border/60 px-3 py-1 text-xs text-muted-foreground">
                #{tag}
              </li>
            ))}
          </ul>
        )}
      </header>

      {cover && (
        <img
          src={cover}
          alt={coverAlt ?? title}
          class="mb-10 w-full rounded-lg border border-border/60"
          loading="eager"
          decoding="async"
        />
      )}

      <div class="prose-blog">
        <slot />
      </div>

      {updatedAt && (
        <p class="mt-12 text-sm text-muted-foreground">
          Última actualización: {dateFormatter.format(updatedAt)}
        </p>
      )}

      <footer class="mt-16 border-t border-border/60 pt-8">
        <a href="/blog/" class="text-sm text-primary hover:underline">
          ← Volver al blog
        </a>
      </footer>
    </article>
  </main>

  <Footer />
  <WaitlistModal />
</BaseLayout>

<style is:global>
  .prose-blog {
    color: oklch(from var(--foreground) l c h / 0.9);
    font-size: 1.0625rem;
    line-height: 1.75;
  }
  .prose-blog > * + * {
    margin-top: 1.25rem;
  }
  .prose-blog h2 {
    margin-top: 2.5rem;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--foreground);
    line-height: 1.3;
  }
  .prose-blog h3 {
    margin-top: 2rem;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--foreground);
  }
  .prose-blog p {
    color: oklch(from var(--foreground) l c h / 0.85);
  }
  .prose-blog a {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose-blog a:hover {
    text-decoration: none;
  }
  .prose-blog strong {
    color: var(--foreground);
    font-weight: 600;
  }
  .prose-blog ul,
  .prose-blog ol {
    padding-left: 1.5rem;
  }
  .prose-blog ul {
    list-style: disc;
  }
  .prose-blog ol {
    list-style: decimal;
  }
  .prose-blog li + li {
    margin-top: 0.4rem;
  }
  .prose-blog blockquote {
    border-left: 3px solid var(--primary);
    padding-left: 1rem;
    color: oklch(from var(--foreground) l c h / 0.75);
    font-style: italic;
  }
  .prose-blog code {
    background: oklch(from var(--foreground) l c h / 0.08);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .prose-blog pre {
    background: oklch(from var(--foreground) l c h / 0.06);
    border: 1px solid oklch(from var(--foreground) l c h / 0.12);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    font-size: 0.9rem;
  }
  .prose-blog pre code {
    background: transparent;
    padding: 0;
  }
  .prose-blog img {
    border-radius: 8px;
    border: 1px solid oklch(from var(--foreground) l c h / 0.12);
  }
  .prose-blog hr {
    border: 0;
    border-top: 1px solid oklch(from var(--foreground) l c h / 0.15);
    margin: 2.5rem 0;
  }
</style>
