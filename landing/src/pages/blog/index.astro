---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import WaitlistModal from "../../components/WaitlistModal.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const dateFormatter = new Intl.DateTimeFormat("es-PE", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout
  title="Blog"
  description="Guías, novedades y buenas prácticas para estudios contables en Perú: SUNAT, comprobantes electrónicos y automatización."
>
  <Header />

  <main class="container mx-auto max-w-3xl px-6 py-16 md:py-24">
    <header class="mb-12">
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-primary">Blog</p>
      <h1 class="mt-3 text-balance text-4xl font-bold leading-tight text-foreground md:text-5xl">
        Lo último de Clearbook
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-muted-foreground">
        Guías prácticas, novedades de SUNAT y aprendizajes para estudios
        contables en Perú.
      </p>
    </header>

    {posts.length === 0 ? (
      <p class="text-muted-foreground">Aún no hay publicaciones. ¡Vuelve pronto!</p>
    ) : (
      <ul class="divide-y divide-border/60">
        {posts.map((post) => (
          <li class="py-8 first:pt-0">
            <a
              href={`/blog/${post.id}/`}
              class="group block"
            >
              <div class="mb-2 flex flex-wrap items-center gap-3 text-xs text-muted-foreground">
                <time datetime={post.data.publishedAt.toISOString()}>
                  {dateFormatter.format(post.data.publishedAt)}
                </time>
                {post.data.tags.length > 0 && (
                  <>
                    <span aria-hidden="true">·</span>
                    <span>{post.data.tags.map((tag: string) => `#${tag}`).join(" ")}</span>
                  </>
                )}
              </div>
              <h2 class="text-2xl font-semibold leading-snug text-foreground transition-colors group-hover:text-primary">
                {post.data.title}
              </h2>
              <p class="mt-2 text-muted-foreground">{post.data.description}</p>
              <span class="mt-3 inline-block text-sm text-primary">
                Leer más →
              </span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </main>

  <Footer />
  <WaitlistModal />
</BaseLayout>
