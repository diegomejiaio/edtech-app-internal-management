---
const footerLinks = {
  producto: [
    { label: "Notificaciones SUNAT", href: "#" },
    { label: "Comprobantes", href: "#" },
    { label: "Multi-Empresa", href: "#" },
    { label: "Reportes", href: "#" },
    { label: "Precios", href: "#" },
  ],
  recursos: [
    { label: "Documentación", href: "#" },
    { label: "Guías de uso", href: "#" },
    { label: "Preguntas frecuentes", href: "#" },
    { label: "Estado del sistema", href: "#" },
  ],
  empresa: [
    { label: "Sobre nosotros", href: "#" },
    { label: "Contacto", href: "#" },
    { label: "Blog", href: "/blog/" },
  ],
  legal: [
    { label: "Privacidad", href: "/privacidad/" },
    { label: "Términos de uso", href: "/terminos/" },
    { label: "Política de cookies", href: "/cookies/" },
  ],
};

const currentYear = new Date().getFullYear();
---

<footer class="border-t bg-muted/30">
  <div class="container py-12 lg:py-16">
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-6">
      <!-- Logo & description -->
      <div class="lg:col-span-2">
        <a href="/">
          <img src="/logo-dark.svg" alt="Clearbook" width="115" height="24" loading="lazy" decoding="async" class="h-6 w-auto dark:hidden" />
          <img src="/logo-light.svg" alt="Clearbook" width="115" height="24" loading="lazy" decoding="async" class="hidden h-6 w-auto dark:block" />
        </a>
        <p class="mt-4 max-w-xs text-sm text-muted-foreground">
          La plataforma para estudios contables que centraliza
          la gestión de documentos tributarios SUNAT.
        </p>

        <div class="mt-6 flex items-center gap-4">
          <div class="flex items-center gap-2 rounded-md bg-muted px-3 py-2 text-xs text-muted-foreground">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
            <span>Datos encriptados</span>
          </div>
        </div>
      </div>

      <!-- Link columns -->
      <div>
        <h3 class="mb-4 text-sm font-semibold">Producto</h3>
        <ul class="space-y-3">
          {footerLinks.producto.map((link) => (
            <li>
              {link.href === "#" ? (
                <span class="cursor-not-allowed text-sm text-muted-foreground/60" aria-disabled="true">{link.label}</span>
              ) : (
                <a href={link.href} class="text-sm text-muted-foreground transition-colors hover:text-foreground">{link.label}</a>
              )}
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-4 text-sm font-semibold">Recursos</h3>
        <ul class="space-y-3">
          {footerLinks.recursos.map((link) => (
            <li>
              {link.href === "#" ? (
                <span class="cursor-not-allowed text-sm text-muted-foreground/60" aria-disabled="true">{link.label}</span>
              ) : (
                <a href={link.href} class="text-sm text-muted-foreground transition-colors hover:text-foreground">{link.label}</a>
              )}
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-4 text-sm font-semibold">Empresa</h3>
        <ul class="space-y-3">
          {footerLinks.empresa.map((link) => (
            <li>
              {link.href === "#" ? (
                <span class="cursor-not-allowed text-sm text-muted-foreground/60" aria-disabled="true">{link.label}</span>
              ) : (
                <a href={link.href} class="text-sm text-muted-foreground transition-colors hover:text-foreground">{link.label}</a>
              )}
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-4 text-sm font-semibold">Legal</h3>
        <ul class="space-y-3">
          {footerLinks.legal.map((link) => (
            <li>
              {link.href === "#" ? (
                <span class="cursor-not-allowed text-sm text-muted-foreground/60" aria-disabled="true">{link.label}</span>
              ) : (
                <a href={link.href} class="text-sm text-muted-foreground transition-colors hover:text-foreground">{link.label}</a>
              )}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t pt-8 md:flex-row">
      <p class="text-sm text-muted-foreground">
        © {currentYear} Clearbook. Todos los derechos reservados.
      </p>
      <p class="text-sm text-muted-foreground">
        Hecho con ❤️ en Perú 🇵🇪
      </p>
    </div>
  </div>
</footer>
