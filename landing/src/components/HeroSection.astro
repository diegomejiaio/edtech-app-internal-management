---
import DashboardMockup from "./DashboardMockup.astro";
import { appUrl } from "../config/site";
---

<section data-hero-field class="hero-section relative isolate overflow-hidden pb-16 pt-24 md:pt-32 lg:pb-24 lg:pt-40">
  <!-- Background gradient -->
  <div class="pointer-events-none absolute inset-0 z-0">
    <div class="hero-dot-grid absolute inset-0"></div>
    <div style="--depth: 0.10" class="hero-glow absolute left-1/2 top-0 h-150 w-200 -translate-x-1/2 -translate-y-1/4 rounded-full bg-primary/20 blur-3xl"></div>
    <div style="--depth: 0.16" class="hero-glow absolute right-0 top-1/4 h-100 w-100 rounded-full bg-primary/10 blur-3xl"></div>
    <div class="hero-lights absolute inset-0" aria-hidden="true">
      <span class="hero-light light-a"></span>
      <span class="hero-light light-b"></span>
      <span class="hero-light light-c"></span>
    </div>
  </div>

  <div class="container relative z-10">
    <div class="mx-auto max-w-4xl text-center">
      <h1 class="hero-title text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl">
        <span class="hero-title-line">
          <span class="hero-word" style="--i: 0">La</span>{" "}
          <span class="hero-word" style="--i: 1">plataforma</span>{" "}
          <span class="hero-word" style="--i: 2">para</span>
        </span>
        <span class="hero-title-line hero-title-accent bg-linear-to-r from-primary via-primary/80 to-primary bg-clip-text text-transparent">
          <span class="hero-word" style="--i: 3">Estudios</span>{" "}
          <span class="hero-word" style="--i: 4">Contables</span>
        </span>
      </h1>

      <p class="animate-fade-in animate-delay-100 mx-auto mt-6 max-w-2xl text-lg text-muted-foreground md:text-xl">
        Centraliza la gestión de notificaciones SUNAT y comprobantes electrónicos
        de todos tus clientes. Automatiza lo manual y enfócate en lo que importa.
      </p>

      <div class="animate-fade-in animate-delay-200 mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <button
          type="button"
          data-waitlist-trigger
          data-hero-magnetic
          class="hero-magnetic-button inline-flex h-12 cursor-pointer items-center justify-center rounded-md bg-primary px-8 text-base font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90"
        >
          Crear una cuenta
          <svg class="ml-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
        </button>
        <a
          href={appUrl("/sign-in")}
          class="inline-flex h-12 items-center justify-center rounded-md border border-border bg-background px-8 text-base font-medium text-foreground shadow-xs transition-colors hover:bg-accent hover:text-accent-foreground dark:border-input dark:bg-input/30 dark:hover:bg-input/50"
        >
          Ya tengo cuenta
        </a>
      </div>
    </div>

    <div class="animate-fade-in animate-delay-300 relative z-10 mx-auto mt-14 max-w-6xl md:mt-16">
      <DashboardMockup />
    </div>
  </div>
</section>

<style>
  .hero-section {
    --mx: 50%;
    --my: 30%;
    --motion-x: 0px;
    --motion-y: 0px;
    background:
      radial-gradient(circle at var(--mx) var(--my), oklch(0.546 0.245 262.881 / 0.12), transparent 28rem),
      linear-gradient(180deg, oklch(0.985 0.003 264.542), oklch(0.955 0.015 264.542));
  }

  :global(.dark) .hero-section {
    background:
      radial-gradient(circle at var(--mx) var(--my), oklch(0.546 0.245 262.881 / 0.16), transparent 28rem),
      linear-gradient(180deg, oklch(0.09 0.018 264.376), oklch(0.06 0.014 264.376));
  }

  .hero-title {
    position: relative;
    text-wrap: balance;
  }

  .hero-title::before {
    content: "";
    position: absolute;
    inset: -18% -8%;
    z-index: -1;
    opacity: 0;
    background: radial-gradient(circle at 50% 50%, oklch(0.546 0.245 262.881 / 0.18), transparent 58%);
    filter: blur(24px);
    animation: title-aura 1.2s ease-out 0.28s both;
  }

  :global(.dark) .hero-title::before {
    background: radial-gradient(circle at 50% 50%, oklch(0.546 0.245 262.881 / 0.28), transparent 58%);
  }

  .hero-title-line {
    display: block;
    overflow: hidden;
    padding-bottom: 0.08em;
  }

  .hero-word {
    display: inline-block;
    opacity: 0;
    filter: blur(14px);
    transform: translate3d(0, 1.05em, 0) rotateX(42deg);
    transform-origin: 50% 100%;
    animation: hero-word-reveal 0.86s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    animation-delay: calc(90ms * var(--i));
  }

  .hero-title-accent {
    background-size: 180% 100%;
    animation: accent-flow 6s ease-in-out infinite;
  }

  .hero-title-accent .hero-word {
    color: transparent;
    background: linear-gradient(
      90deg,
      var(--primary),
      oklch(0.70 0.22 255),
      var(--primary)
    );
    background-size: 180% 100%;
    background-clip: text;
    -webkit-background-clip: text;
  }

  .hero-magnetic-button {
    --magnetic-x: 0px;
    --magnetic-y: 0px;
    --magnetic-scale: 1;
    position: relative;
    transform: translate3d(var(--magnetic-x), var(--magnetic-y), 0) scale(var(--magnetic-scale));
    transition:
      transform 180ms ease-out,
      background-color 150ms ease-out,
      box-shadow 150ms ease-out;
    will-change: transform;
  }

  .hero-magnetic-button::before {
    content: "";
    position: absolute;
    inset: -14px;
    border-radius: 18px;
  }

  .hero-magnetic-button:hover {
    box-shadow: 0 16px 42px -18px oklch(0.546 0.245 262.881 / 0.9);
  }

  .hero-dot-grid {
    opacity: 0.28;
    background-image:
      radial-gradient(oklch(0.13 0.028 261.692 / 0.12) 1px, transparent 1px),
      radial-gradient(oklch(0.546 0.245 262.881 / 0.14) 1px, transparent 1px);
    background-position:
      calc(var(--motion-x) * -0.18) calc(var(--motion-y) * -0.18),
      calc(11px + var(--motion-x) * 0.12) calc(11px + var(--motion-y) * 0.12);
    background-size: 24px 24px, 48px 48px;
    mask-image: radial-gradient(ellipse at center, black 36%, transparent 76%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 36%, transparent 76%);
  }

  :global(.dark) .hero-dot-grid {
    opacity: 0.34;
    background-image:
      radial-gradient(oklch(1 0 0 / 0.14) 1px, transparent 1px),
      radial-gradient(oklch(0.546 0.245 262.881 / 0.18) 1px, transparent 1px);
  }

  .hero-dot-grid::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at var(--mx) var(--my), oklch(0.546 0.245 262.881 / 0.10), transparent 18rem);
    mix-blend-mode: multiply;
  }

  :global(.dark) .hero-dot-grid::after {
    background: radial-gradient(circle at var(--mx) var(--my), oklch(1 0 0 / 0.16), transparent 18rem);
    mix-blend-mode: screen;
  }

  .hero-glow {
    transform: translate3d(calc(var(--motion-x) * var(--depth, 0.1)), calc(var(--motion-y) * var(--depth, 0.1)), 0);
  }

  .hero-lights {
    transform: translate3d(calc(var(--motion-x) * 0.06), calc(var(--motion-y) * 0.06), 0);
  }

  .hero-light {
    position: absolute;
    display: block;
    width: 22rem;
    height: 22rem;
    border-radius: 999px;
    filter: blur(52px);
    mix-blend-mode: multiply;
    opacity: 0.28;
    will-change: transform, opacity;
  }

  :global(.dark) .hero-light {
    mix-blend-mode: screen;
    opacity: 0.46;
  }

  .light-a {
    left: 7%;
    top: 16%;
    background: radial-gradient(circle, oklch(0.62 0.22 255 / 0.92), transparent 68%);
    animation: hero-light-a 14s ease-in-out infinite;
  }

  .light-b {
    right: 6%;
    top: 24%;
    width: 18rem;
    height: 18rem;
    background: radial-gradient(circle, oklch(0.70 0.17 200 / 0.78), transparent 66%);
    animation: hero-light-b 16s ease-in-out infinite;
  }

  .light-c {
    left: 42%;
    bottom: 8%;
    width: 24rem;
    height: 24rem;
    background: radial-gradient(circle, oklch(0.78 0.16 145 / 0.58), transparent 70%);
    animation: hero-light-c 18s ease-in-out infinite;
  }

  @keyframes title-aura {
    0% { opacity: 0; transform: scale(0.72); }
    42% { opacity: 0.9; transform: scale(1); }
    100% { opacity: 0.38; transform: scale(1.1); }
  }

  @keyframes hero-word-reveal {
    0% {
      opacity: 0;
      filter: blur(14px);
      transform: translate3d(0, 1.05em, 0) rotateX(42deg);
    }
    62% {
      opacity: 1;
      filter: blur(1px);
      transform: translate3d(0, -0.04em, 0) rotateX(0deg);
    }
    100% {
      opacity: 1;
      filter: blur(0);
      transform: translate3d(0, 0, 0) rotateX(0deg);
    }
  }

  @keyframes accent-flow {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  @keyframes hero-light-a {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); opacity: 0.26; }
    45% { transform: translate3d(9rem, 4rem, 0) scale(1.22); opacity: 0.48; }
    72% { transform: translate3d(3rem, 8rem, 0) scale(0.92); opacity: 0.34; }
  }

  @keyframes hero-light-b {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); opacity: 0.24; }
    45% { transform: translate3d(-8rem, 6rem, 0) scale(1.16); opacity: 0.44; }
    74% { transform: translate3d(-3rem, -2rem, 0) scale(0.94); opacity: 0.3; }
  }

  @keyframes hero-light-c {
    0%, 100% { transform: translate3d(0, 0, 0) scale(0.92); opacity: 0.18; }
    52% { transform: translate3d(-5rem, -6rem, 0) scale(1.18); opacity: 0.36; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title::before,
    .hero-word,
    .hero-title-accent,
    .hero-light {
      animation: none;
    }

    .hero-word {
      opacity: 1;
      filter: none;
      transform: none;
    }

    .hero-magnetic-button {
      transform: none;
    }
  }
</style>

<script>
  let cleanupHeroField: (() => void) | undefined;

  function setupHeroField() {
    cleanupHeroField?.();
    const section = document.querySelector<HTMLElement>("[data-hero-field]");
    if (!section) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced) return;

    let frame = 0;
    let targetX = 0;
    let targetY = 0;
    let currentX = 0;
    let currentY = 0;
    const magneticButton = section.querySelector<HTMLElement>("[data-hero-magnetic]");

    const render = () => {
      currentX += (targetX - currentX) * 0.09;
      currentY += (targetY - currentY) * 0.09;
      section.style.setProperty("--motion-x", `${currentX.toFixed(2)}px`);
      section.style.setProperty("--motion-y", `${currentY.toFixed(2)}px`);
      frame = requestAnimationFrame(render);
    };

    const onPointerMove = (event: PointerEvent) => {
      const rect = section.getBoundingClientRect();
      const x = event.clientX - rect.left;
      const y = event.clientY - rect.top;
      targetX = (x / rect.width - 0.5) * 64;
      targetY = (y / rect.height - 0.5) * 48;
      section.style.setProperty("--mx", `${(x / rect.width) * 100}%`);
      section.style.setProperty("--my", `${(y / rect.height) * 100}%`);
    };

    const onPointerLeave = () => {
      targetX = 0;
      targetY = 0;
      section.style.setProperty("--mx", "50%");
      section.style.setProperty("--my", "30%");
    };

    const onMagneticMove = (event: PointerEvent) => {
      if (!magneticButton) return;
      const rect = magneticButton.getBoundingClientRect();
      const x = event.clientX - rect.left - rect.width / 2;
      const y = event.clientY - rect.top - rect.height / 2;
      magneticButton.style.setProperty("--magnetic-x", `${(x * 0.22).toFixed(2)}px`);
      magneticButton.style.setProperty("--magnetic-y", `${(y * 0.32).toFixed(2)}px`);
      magneticButton.style.setProperty("--magnetic-scale", "1.035");
    };

    const onMagneticLeave = () => {
      if (!magneticButton) return;
      magneticButton.style.setProperty("--magnetic-x", "0px");
      magneticButton.style.setProperty("--magnetic-y", "0px");
      magneticButton.style.setProperty("--magnetic-scale", "1");
    };

    section.addEventListener("pointermove", onPointerMove);
    section.addEventListener("pointerleave", onPointerLeave);
    magneticButton?.addEventListener("pointermove", onMagneticMove);
    magneticButton?.addEventListener("pointerleave", onMagneticLeave);
    frame = requestAnimationFrame(render);

    cleanupHeroField = () => {
      section.removeEventListener("pointermove", onPointerMove);
      section.removeEventListener("pointerleave", onPointerLeave);
      magneticButton?.removeEventListener("pointermove", onMagneticMove);
      magneticButton?.removeEventListener("pointerleave", onMagneticLeave);
      cancelAnimationFrame(frame);
    };
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupHeroField, { once: true });
  } else {
    setupHeroField();
  }

  document.addEventListener("astro:before-swap", () => cleanupHeroField?.());
  document.addEventListener("astro:after-swap", setupHeroField);
</script>
