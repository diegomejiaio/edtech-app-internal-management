---
import DeclarationButton from "./DeclarationButton.astro";
---

<section class="py-16 lg:py-24" id="declaracion-un-clic">
  <div class="container">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm font-medium uppercase tracking-wider text-primary-text">
        Un solo clic
      </p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl md:text-5xl">
        Realiza la declaración mensual sin abrir SUNAT
      </h2>
      <p class="mt-4 text-lg text-muted-foreground">
        Clearbook valida los comprobantes, calcula el IGV y prepara la
        declaración. Tú solo confirmas. Miles de declaraciones procesadas
        cada mes.
      </p>
    </div>

    <div class="mt-10 flex justify-center">
      <DeclarationButton />
    </div>
  </div>
</section>
