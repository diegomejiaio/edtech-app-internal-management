---
import HeroMockup from "./HeroMockup.astro";
---

<section id="unified-management" class="relative isolate overflow-hidden py-16 lg:py-24">
  <div class="pointer-events-none absolute inset-0 z-0">
    <div class="dot-grid absolute inset-0"></div>
    <div class="absolute left-1/2 top-1/3 h-125 w-175 -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/10 blur-3xl"></div>
  </div>

  <div class="container relative z-10">
    <div data-unified-text class="mx-auto max-w-3xl text-center">
      <p data-anim="eyebrow" class="text-sm font-medium uppercase tracking-wider text-primary-text">
        Una sola plataforma
      </p>
      <h2 data-anim="heading" class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl md:text-5xl">
        Gestión unificada e integrada de la contabilidad
      </h2>
      <p data-anim="lede" class="mt-4 text-lg text-muted-foreground">
        Notificaciones SUNAT, comprobantes electrónicos y todas las gestiones
        de tus clientes en un mismo lugar. Sin saltar entre portales, sin
        descargas manuales.
      </p>
    </div>

    <div data-unified-mockup class="relative mx-auto mt-12 max-w-7xl lg:mt-16 lg:scale-110 xl:scale-125">
      <HeroMockup />
      <div data-anim="ai-badge" class="ai-console-anchor">
        <div class="ai-console">
          <div class="ai-orb" aria-hidden="true">
            <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z" /></svg>
          </div>
          <div class="min-w-0 text-left">
            <p class="text-[0.62rem] font-semibold uppercase tracking-wider text-primary/80">Powered by Clearbook AI</p>
            <p data-ai-command class="ai-command">Validando comprobantes en tiempo real</p>
          </div>
          <div class="ai-console-steps" aria-hidden="true">
            <span>TC</span>
            <span>CPE</span>
            <span>SIRE</span>
          </div>
        </div>
      </div>
      <div data-ai-flow class="ai-flow-layer" aria-hidden="true">
        <span class="ai-pulse pulse-a"></span>
        <span class="ai-pulse pulse-b"></span>
        <span class="ai-pulse pulse-c"></span>
        <span class="ai-pulse pulse-d"></span>
        <span class="ai-scan"></span>
      </div>
    </div>
  </div>
</section>

<style>
  /* n8n-style dotted canvas background */
  .dot-grid {
    background-image: radial-gradient(
      oklch(0.13 0.028 261.692 / 0.10) 1.2px,
      transparent 1.2px
    );
    background-size: 22px 22px;
    background-position: 0 0;
    mask-image: radial-gradient(
      ellipse at center,
      black 55%,
      transparent 85%
    );
    -webkit-mask-image: radial-gradient(
      ellipse at center,
      black 55%,
      transparent 85%
    );
  }

  :global(.dark) .dot-grid {
    background-image: radial-gradient(
      oklch(1 0 0 / 0.10) 1.2px,
      transparent 1.2px
    );
  }

  .ai-console-anchor {
    pointer-events: none;
    position: absolute;
    left: 50%;
    top: 62%;
    z-index: 4;
    width: max-content;
    max-width: min(calc(100% - 2rem), 29rem);
    transform: translateX(-50%);
  }

  .ai-console {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    width: 100%;
    overflow: hidden;
    border: 1px solid oklch(0.546 0.245 262.881 / 0.28);
    border-radius: 999px;
    background:
      linear-gradient(90deg, oklch(0.546 0.245 262.881 / 0.16), transparent 38%),
      oklch(1 0 0 / 0.68);
    box-shadow: 0 14px 38px oklch(0.546 0.245 262.881 / 0.13);
    padding: 0.48rem 0.62rem;
    color: oklch(0.546 0.245 262.881);
    backdrop-filter: blur(18px);
  }

  :global(.dark) .ai-console {
    background:
      linear-gradient(90deg, oklch(0.546 0.245 262.881 / 0.22), transparent 40%),
      oklch(0.12 0.018 264.376 / 0.76);
    box-shadow: 0 16px 44px oklch(0.546 0.245 262.881 / 0.20);
  }

  .ai-console::after {
    content: "";
    position: absolute;
    inset: 0;
    transform: translateX(-120%);
    background: linear-gradient(90deg, transparent, oklch(1 0 0 / 0.28), transparent);
    animation: ai-console-shine 4.8s ease-in-out infinite;
  }

  .ai-orb {
    position: relative;
    z-index: 1;
    display: grid;
    height: 2.15rem;
    width: 2.15rem;
    flex: 0 0 auto;
    place-items: center;
    border-radius: 999px;
    background: oklch(0.546 0.245 262.881);
    color: white;
    box-shadow: 0 0 0 0 oklch(0.546 0.245 262.881 / 0.32);
  }

  .ai-orb::before,
  .ai-orb::after {
    content: "";
    position: absolute;
    inset: -0.22rem;
    border: 1px solid oklch(0.546 0.245 262.881 / 0.25);
    border-radius: inherit;
  }

  .ai-orb::after {
    inset: -0.44rem;
    opacity: 0.55;
  }

  .ai-command {
    position: relative;
    z-index: 1;
    min-width: 15rem;
    color: oklch(0.21 0.034 264.665);
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1.25;
  }

  :global(.dark) .ai-command {
    color: oklch(0.985 0.003 264.542);
  }

  .ai-console-steps {
    position: relative;
    z-index: 1;
    display: flex;
    gap: 0.28rem;
  }

  .ai-console-steps span {
    border-radius: 999px;
    background: oklch(0.546 0.245 262.881 / 0.12);
    padding: 0.22rem 0.4rem;
    color: oklch(0.546 0.245 262.881);
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  .ai-flow-layer {
    pointer-events: none;
    position: absolute;
    inset: 0;
    z-index: 0;
    display: none;
  }

  :global(#hero-svg-container) {
    position: relative;
    z-index: 1;
  }

  .ai-pulse {
    position: absolute;
    left: 50%;
    top: 50%;
    height: 0.34rem;
    width: 0.34rem;
    border-radius: 999px;
    background: oklch(0.546 0.245 262.881);
    box-shadow: 0 0 12px oklch(0.546 0.245 262.881 / 0.75);
    opacity: 0;
  }

  .ai-scan {
    position: absolute;
    left: 26%;
    top: 46%;
    height: 1px;
    width: 48%;
    background: linear-gradient(90deg, transparent, oklch(0.546 0.245 262.881 / 0.9), transparent);
    filter: drop-shadow(0 0 10px oklch(0.546 0.245 262.881 / 0.7));
    opacity: 0;
  }

  @media (min-width: 768px) {
    .ai-flow-layer {
      display: block;
    }
  }

  @media (max-width: 640px) {
    .ai-console-anchor {
      top: 64%;
      max-width: min(calc(100% - 1rem), 24rem);
    }

    .ai-console {
      border-radius: 1.2rem;
      align-items: flex-start;
    }

    .ai-command {
      min-width: 0;
    }

    .ai-console-steps {
      display: none;
    }
  }

  @keyframes ai-console-shine {
    0%, 42% { transform: translateX(-120%); }
    62%, 100% { transform: translateX(120%); }
  }

  /* Pre-animation hidden state. Removed by JS once animation runs.
     Reduced-motion users skip the script and see everything via fallback. */
  [data-unified-text][data-anim-pending] [data-anim] {
    opacity: 0;
  }
  [data-unified-text][data-anim-pending] .word {
    opacity: 0;
    display: inline-block;
    transform: translateY(0.6em);
  }
  [data-unified-mockup][data-anim-pending] {
    opacity: 0;
    transform: translateY(24px);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-unified-text][data-anim-pending] [data-anim],
    [data-unified-text][data-anim-pending] .word,
    [data-unified-mockup][data-anim-pending],
    [data-ai-flow] .ai-scan,
    [data-ai-flow] .ai-pulse {
      opacity: 1;
      transform: none;
    }

    .ai-console::after {
      animation: none;
    }
  }
</style>

<script>
  import { animate, stagger } from "animejs";

  let initialized = false;
  let aiCommandInterval: number | undefined;

  const aiCommands = [
    "Validando comprobantes en tiempo real",
    "Detectando observaciones antes del cierre",
    "Cruzando TC, detracciones y montos",
    "Preparando la declaración mensual",
  ];

  function splitWords(el: HTMLElement) {
    if (el.querySelector(".word")) return; // already split
    const text = el.textContent ?? "";
    el.textContent = "";
    text.split(/(\s+)/).forEach((chunk) => {
      if (/^\s+$/.test(chunk)) {
        el.appendChild(document.createTextNode(chunk));
      } else if (chunk.length > 0) {
        const span = document.createElement("span");
        span.className = "word";
        span.style.display = "inline-block";
        span.style.willChange = "transform, opacity";
        span.textContent = chunk;
        el.appendChild(span);
      }
    });
  }

  function initUnified() {
    if (initialized) return;
    const textBlock = document.querySelector<HTMLElement>("[data-unified-text]");
    const mockupBlock = document.querySelector<HTMLElement>("[data-unified-mockup]");
    if (!textBlock || !mockupBlock) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    textBlock.setAttribute("data-anim-pending", "");
    mockupBlock.setAttribute("data-anim-pending", "");

    if (reduced) {
      textBlock.removeAttribute("data-anim-pending");
      mockupBlock.removeAttribute("data-anim-pending");
      initialized = true;
      return;
    }

    // Split heading and lede into words for staggered reveal.
    const heading = textBlock.querySelector<HTMLElement>('[data-anim="heading"]');
    const lede = textBlock.querySelector<HTMLElement>('[data-anim="lede"]');
    if (heading) splitWords(heading);
    if (lede) splitWords(lede);

    const observer = new IntersectionObserver(
      (entries) => {
        if (!entries[0].isIntersecting) return;
        observer.disconnect();

        textBlock.removeAttribute("data-anim-pending");
        mockupBlock.removeAttribute("data-anim-pending");

        animate('[data-unified-text] [data-anim="eyebrow"]', {
          opacity: { from: 0, to: 1 },
          translateY: { from: 8, to: 0 },
          duration: 500,
          ease: "out(3)",
        });

        animate('[data-unified-text] [data-anim="heading"] .word', {
          opacity: { from: 0, to: 1 },
          translateY: { from: 18, to: 0 },
          duration: 650,
          delay: stagger(45, { start: 120 }),
          ease: "out(3)",
        });

        animate('[data-unified-text] [data-anim="lede"] .word', {
          opacity: { from: 0, to: 1 },
          translateY: { from: 10, to: 0 },
          duration: 500,
          delay: stagger(18, { start: 450 }),
          ease: "out(2)",
        });

        animate('[data-unified-mockup] [data-anim="ai-badge"] .ai-console', {
          opacity: { from: 0, to: 1 },
          translateY: { from: 12, to: 0 },
          scale: { from: 0.96, to: 1 },
          duration: 600,
          delay: 700,
          ease: "out(3)",
        });

        animate(".ai-orb", {
          scale: [1, 1.08, 1],
          boxShadow: [
            "0 0 0 0 oklch(0.546 0.245 262.881 / 0.28)",
            "0 0 0 16px oklch(0.546 0.245 262.881 / 0)",
          ],
          duration: 1800,
          delay: 900,
          loop: true,
          ease: "inOut(2)",
        });

        animate(".ai-console-steps span", {
          translateY: [0, -3, 0],
          opacity: [0.65, 1, 0.65],
          duration: 1200,
          delay: stagger(180, { start: 1000 }),
          loop: true,
          ease: "inOut(2)",
        });

        animate("[data-ai-flow] .ai-scan", {
          opacity: [0, 1, 0],
          translateY: [-70, 70],
          duration: 2200,
          delay: 1200,
          loop: true,
          ease: "inOut(2)",
        });

        animate("[data-ai-flow] .pulse-a", {
          opacity: [0, 1, 0],
          translateX: [-360, -40, 0],
          translateY: [-170, -30, 0],
          scale: [0.45, 0.95, 0.25],
          duration: 2300,
          delay: 1200,
          loop: true,
          ease: "out(3)",
        });

        animate("[data-ai-flow] .pulse-b", {
          opacity: [0, 1, 0],
          translateX: [360, 50, 0],
          translateY: [-160, -20, 0],
          scale: [0.45, 0.95, 0.25],
          duration: 2300,
          delay: 1600,
          loop: true,
          ease: "out(3)",
        });

        animate("[data-ai-flow] .pulse-c", {
          opacity: [0, 1, 0],
          translateX: [-430, -80, 0],
          translateY: [20, 8, 0],
          scale: [0.45, 0.95, 0.25],
          duration: 2300,
          delay: 2000,
          loop: true,
          ease: "out(3)",
        });

        animate("[data-ai-flow] .pulse-d", {
          opacity: [0, 1, 0],
          translateX: [430, 80, 0],
          translateY: [20, 8, 0],
          scale: [0.45, 0.95, 0.25],
          duration: 2300,
          delay: 2400,
          loop: true,
          ease: "out(3)",
        });

        startAiCommandCycle();

        animate("[data-unified-mockup]", {
          opacity: { from: 0, to: 1 },
          translateY: { from: 24, to: 0 },
          duration: 800,
          delay: 350,
          ease: "out(3)",
        });
      },
      { threshold: 0, rootMargin: "0px 0px -10% 0px" },
    );
    observer.observe(textBlock);
    initialized = true;
  }

  function startAiCommandCycle() {
    const command = document.querySelector<HTMLElement>("[data-ai-command]");
    if (!command || aiCommandInterval) return;
    let index = 0;
    aiCommandInterval = window.setInterval(() => {
      index = (index + 1) % aiCommands.length;
      animate(command, {
        opacity: { from: 1, to: 0 },
        translateY: { from: 0, to: -6 },
        duration: 180,
        ease: "in(2)",
        onComplete: () => {
          command.textContent = aiCommands[index];
          animate(command, {
            opacity: { from: 0, to: 1 },
            translateY: { from: 8, to: 0 },
            duration: 260,
            ease: "out(3)",
          });
        },
      });
    }, 2400);
  }

  function reset() {
    initialized = false;
    if (aiCommandInterval) {
      window.clearInterval(aiCommandInterval);
      aiCommandInterval = undefined;
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initUnified);
  } else {
    initUnified();
  }

  document.addEventListener("astro:before-swap", reset);
  document.addEventListener("astro:after-swap", initUnified);
</script>
