---
const stats = [
  {
    value: "500+",
    label: "Empresas gestionadas",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/></svg>',
  },
  {
    value: "50K+",
    label: "Comprobantes sincronizados",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>',
  },
  {
    value: "10K+",
    label: "Notificaciones procesadas",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>',
  },
  {
    value: "100+",
    label: "Contadores activos",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
  },
];
---

<section id="resultados" class="border-y bg-muted/30 py-12 lg:py-16">
  <div class="container">
    <div class="animate-fade-in mx-auto mb-8 max-w-2xl text-center">
      <p class="text-sm font-medium uppercase tracking-wider text-primary-text">
        Automatización tributaria
      </p>
      <h2 class="mt-2 text-2xl font-bold tracking-tight sm:text-3xl">
        Operación contable con volumen real
      </h2>
      <p class="mt-3 text-base text-muted-foreground">
        Centraliza empresas, comprobantes y notificaciones para que el equipo
        trabaje sobre alertas claras, no sobre tareas repetitivas.
      </p>
    </div>

    <div class="animate-fade-in animate-delay-100 grid grid-cols-2 gap-8 md:grid-cols-4">
      {stats.map((stat) => (
        <div class="flex flex-col items-center gap-2 text-center">
          <span class="text-primary/60" set:html={stat.icon} />
          <span class="text-2xl font-bold tracking-tight lg:text-3xl">
            {stat.value}
          </span>
          <span class="text-sm text-muted-foreground">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
