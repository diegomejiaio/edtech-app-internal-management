---
/**
 * WaitlistModal — full-screen Typeform-style waitlist form.
 *
 * Open via: window.openWaitlist() or any element with data-waitlist-trigger.
 * Backend: Google Apps Script (see landing/apps-script/README.md).
 *
 * Steps: nombre → email → ruc → clientes → herramientas → success.
 * Navigation: Enter to advance, Esc to close, ↑/↓ for option groups.
 *
 * Note on WAITLIST_URL:
 * This is hardcoded intentionally. It's a public POST endpoint with no auth,
 * no secrets, no privileged access — just like a Typeform URL. Any PUBLIC_*
 * env var would end up in the client bundle anyway, so the env var indirection
 * adds zero security and only adds CI/CD complexity. If we ever need different
 * backends per environment (dev/prod), revert this to import.meta.env.
 */
const WAITLIST_URL =
  "https://script.google.com/macros/s/AKfycbyh-TRxq18-vTsJz4tDB--EQBSLz0oY8-go0AnMrm6lpS-hh3bsCH7zGniqErhMASFo/exec";

const clientesOptions = [
  { value: "1-5", label: "1 a 5 clientes", letter: "A" },
  { value: "6-20", label: "6 a 20 clientes", letter: "B" },
  { value: "21-50", label: "21 a 50 clientes", letter: "C" },
  { value: "51-100", label: "51 a 100 clientes", letter: "D" },
  { value: "100+", label: "Más de 100 clientes", letter: "E" },
];

const herramientasOptions = [
  { value: "Excel", label: "Excel", letter: "A" },
  { value: "Concar", label: "Concar", letter: "B" },
  { value: "Siscont", label: "Siscont", letter: "C" },
  { value: "ContaSIS", label: "ContaSIS", letter: "D" },
  { value: "Foxcont", label: "Foxcont", letter: "E" },
  { value: "Otro ERP", label: "Otro ERP", letter: "F" },
  { value: "Solo SUNAT web", label: "Solo SUNAT web", letter: "G" },
  { value: "Ninguna", label: "Ninguna", letter: "H" },
];
---

<div
  id="waitlist-modal"
  class="fixed inset-0 z-50 hidden bg-background"
  role="dialog"
  aria-modal="true"
  aria-labelledby="waitlist-title"
>
  <!-- Header bar -->
  <div class="absolute left-0 right-0 top-0 z-10 flex items-center justify-between px-6 py-4">
    <div class="flex items-center gap-2">
      <img src="/logo-dark.svg" alt="Clearbook" width="115" height="24" loading="lazy" decoding="async" class="h-6 w-auto dark:hidden" />
      <img src="/logo-light.svg" alt="Clearbook" width="115" height="24" loading="lazy" decoding="async" class="hidden h-6 w-auto dark:block" />
      <span class="ml-1 hidden text-xs text-muted-foreground sm:inline">· Crear cuenta</span>
    </div>
    <div class="flex items-center gap-1">
      <button
        id="waitlist-back"
        type="button"
        aria-label="Pregunta anterior"
        class="hidden rounded-md p-2 text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button
        id="waitlist-close"
        type="button"
        aria-label="Cerrar formulario"
        class="rounded-md p-2 text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Progress bar -->
  <div class="absolute left-0 right-0 top-[60px] z-10 h-1 bg-muted">
    <div id="waitlist-progress" class="h-full bg-primary transition-all duration-300" style="width: 0%"></div>
  </div>

  <!-- Steps container -->
  <div id="waitlist-steps" class="relative h-full overflow-hidden">

    <!-- STEP 1: nombre -->
    <div class="waitlist-step absolute inset-0 flex items-start justify-center overflow-y-auto px-6 pt-24 pb-16 sm:pt-[20vh]" data-step="1">
      <div class="w-full max-w-xl">
        <div class="mb-2 flex items-center gap-2 text-xs text-muted-foreground">
          <span class="font-medium">1</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
        </div>
        <h2 id="waitlist-title" class="text-2xl font-semibold text-foreground sm:text-3xl">
          ¿Cuál es tu nombre? <span class="text-destructive">*</span>
        </h2>
        <input
          type="text"
          name="nombre"
          autocomplete="name"
          maxlength="80"
          placeholder="Escribe tu nombre aquí..."
          aria-labelledby="waitlist-title"
          aria-required="true"
          aria-describedby="waitlist-error-1"
          class="mt-8 w-full border-0 border-b-2 border-border bg-transparent pb-3 text-2xl text-foreground placeholder:text-muted-foreground/50 focus:border-primary focus:outline-none sm:text-3xl"
        />
        <div id="waitlist-error-1" class="waitlist-error mt-3 hidden text-sm text-destructive" role="alert" aria-live="polite"></div>
        <div class="mt-10 flex items-center gap-3">
          <button type="button" data-action="next" class="waitlist-btn-next inline-flex h-12 items-center gap-2 rounded-md bg-primary px-6 text-base font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90">
            OK
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </button>
          <span class="text-xs text-muted-foreground">presiona <kbd class="rounded border border-border bg-muted px-1.5 py-0.5 font-mono text-[10px] uppercase">Enter</kbd></span>
        </div>
      </div>
    </div>

    <!-- STEP 2: email -->
    <div class="waitlist-step absolute inset-0 flex items-start justify-center overflow-y-auto px-6 pt-24 pb-16 sm:pt-[20vh]" data-step="2">
      <div class="w-full max-w-xl">
        <div class="mb-2 flex items-center gap-2 text-xs text-muted-foreground">
          <span class="font-medium">2</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
        </div>
        <h2 id="waitlist-title-2" class="text-2xl font-semibold text-foreground sm:text-3xl">
          ¿A qué email te avisamos? <span class="text-destructive">*</span>
        </h2>
        <p class="mt-2 text-sm text-muted-foreground">Te escribimos cuando abramos acceso para tu estudio.</p>
        <input
          type="email"
          name="email"
          autocomplete="email"
          inputmode="email"
          placeholder="nombre@estudio.pe"
          aria-labelledby="waitlist-title-2"
          aria-required="true"
          aria-describedby="waitlist-error-2"
          class="mt-8 w-full border-0 border-b-2 border-border bg-transparent pb-3 text-2xl text-foreground placeholder:text-muted-foreground/50 focus:border-primary focus:outline-none sm:text-3xl"
        />
        <div id="waitlist-error-2" class="waitlist-error mt-3 hidden text-sm text-destructive" role="alert" aria-live="polite"></div>
        <div class="mt-10 flex items-center gap-3">
          <button type="button" data-action="next" class="waitlist-btn-next inline-flex h-12 items-center gap-2 rounded-md bg-primary px-6 text-base font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90">
            OK
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </button>
          <span class="text-xs text-muted-foreground">presiona <kbd class="rounded border border-border bg-muted px-1.5 py-0.5 font-mono text-[10px] uppercase">Enter</kbd></span>
        </div>
      </div>
    </div>

    <!-- STEP 3: RUC -->
    <div class="waitlist-step absolute inset-0 flex items-start justify-center overflow-y-auto px-6 pt-24 pb-16 sm:pt-[20vh]" data-step="3">
      <div class="w-full max-w-xl">
        <div class="mb-2 flex items-center gap-2 text-xs text-muted-foreground">
          <span class="font-medium">3</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
        </div>
        <h2 id="waitlist-title-3" class="text-2xl font-semibold text-foreground sm:text-3xl">
          RUC del estudio <span class="text-destructive">*</span>
        </h2>
        <p class="mt-2 text-sm text-muted-foreground">11 dígitos. Lo usamos solo para reconocer tu estudio.</p>
        <input
          type="text"
          name="ruc"
          inputmode="numeric"
          maxlength="11"
          pattern="[0-9]{11}"
          placeholder="20612611620"
          aria-labelledby="waitlist-title-3"
          aria-required="true"
          aria-describedby="waitlist-error-3"
          class="mt-8 w-full border-0 border-b-2 border-border bg-transparent pb-3 font-mono text-2xl tracking-wider text-foreground placeholder:text-muted-foreground/50 focus:border-primary focus:outline-none sm:text-3xl"
        />
        <div id="waitlist-error-3" class="waitlist-error mt-3 hidden text-sm text-destructive" role="alert" aria-live="polite"></div>
        <div class="mt-10 flex items-center gap-3">
          <button type="button" data-action="next" class="waitlist-btn-next inline-flex h-12 items-center gap-2 rounded-md bg-primary px-6 text-base font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90">
            OK
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </button>
          <span class="text-xs text-muted-foreground">presiona <kbd class="rounded border border-border bg-muted px-1.5 py-0.5 font-mono text-[10px] uppercase">Enter</kbd></span>
        </div>
      </div>
    </div>

    <!-- STEP 4: clientes -->
    <div class="waitlist-step absolute inset-0 flex items-start justify-center overflow-y-auto px-6 pt-24 pb-16 sm:pt-[20vh]" data-step="4">
      <div class="w-full max-w-xl">
        <div class="mb-2 flex items-center gap-2 text-xs text-muted-foreground">
          <span class="font-medium">4</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
        </div>
        <h2 id="waitlist-title-4" class="text-2xl font-semibold text-foreground sm:text-3xl">
          ¿Cuántos clientes manejas? <span class="text-destructive">*</span>
        </h2>
        <p class="mt-2 text-sm text-muted-foreground">Selecciona uno.</p>
        <div class="mt-8 space-y-2" role="radiogroup" aria-labelledby="waitlist-title-4" data-options="clientes" data-multi="false">
          {clientesOptions.map((opt) => (
            <button
              type="button"
              class="waitlist-option group flex w-full items-center gap-3 rounded-md border border-border bg-card px-4 py-3 text-left transition-colors hover:border-primary hover:bg-primary/5 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
              data-value={opt.value}
            >
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded border border-border bg-background font-mono text-xs font-semibold text-foreground/80 group-hover:border-primary group-hover:bg-primary group-hover:text-primary-foreground">
                {opt.letter}
              </span>
              <span class="flex-1 text-base text-foreground">{opt.label}</span>
              <svg class="hidden h-4 w-4 text-primary" data-checkmark width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </button>
          ))}
        </div>
        <div id="waitlist-error-4" class="waitlist-error mt-3 hidden text-sm text-destructive" role="alert" aria-live="polite"></div>
        <div class="mt-6 flex items-center gap-3">
          <span class="text-xs text-muted-foreground">presiona la <kbd class="rounded border border-border bg-muted px-1.5 py-0.5 font-mono text-[10px] uppercase">tecla</kbd> o haz click</span>
        </div>
      </div>
    </div>

    <!-- STEP 5: herramientas -->
    <div class="waitlist-step absolute inset-0 flex items-start justify-center overflow-y-auto px-6 pt-24 pb-16 sm:pt-[20vh]" data-step="5">
      <div class="w-full max-w-2xl">
        <div class="mb-2 flex items-center gap-2 text-xs text-muted-foreground">
          <span class="font-medium">5</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
        </div>
        <h2 id="waitlist-title-5" class="text-2xl font-semibold text-foreground sm:text-3xl">
          ¿Qué herramientas usas hoy? <span class="text-destructive">*</span>
        </h2>
        <p class="mt-2 text-sm text-muted-foreground">Selecciona todas las que apliquen.</p>
        <div class="mt-8 grid grid-cols-1 gap-2 sm:grid-cols-2" role="group" aria-labelledby="waitlist-title-5" data-options="herramientas" data-multi="true">
          {herramientasOptions.map((opt) => (
            <button
              type="button"
              class="waitlist-option group flex w-full items-center gap-3 rounded-md border border-border bg-card px-4 py-3 text-left transition-colors hover:border-primary hover:bg-primary/5 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
              data-value={opt.value}
            >
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded border border-border bg-background font-mono text-xs font-semibold text-foreground/80 group-hover:border-primary group-hover:bg-primary group-hover:text-primary-foreground">
                {opt.letter}
              </span>
              <span class="flex-1 text-base text-foreground">{opt.label}</span>
              <svg class="hidden h-4 w-4 text-primary" data-checkmark width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </button>
          ))}
        </div>
        <div id="waitlist-error-5" class="waitlist-error mt-3 hidden text-sm text-destructive" role="alert" aria-live="polite"></div>
        <div class="mt-8 flex items-center gap-3">
          <button type="button" data-action="submit" class="waitlist-btn-submit inline-flex h-12 items-center gap-2 rounded-md bg-primary px-6 text-base font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90 disabled:opacity-50">
            <span class="waitlist-submit-label">Enviar</span>
            <svg class="waitlist-submit-spinner hidden h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </button>
          <span class="text-xs text-muted-foreground">presiona <kbd class="rounded border border-border bg-muted px-1.5 py-0.5 font-mono text-[10px] uppercase">Enter</kbd> para enviar</span>
        </div>
      </div>
    </div>

    <!-- STEP 6: success -->
    <div class="waitlist-step absolute inset-0 flex items-start justify-center overflow-y-auto px-6 pt-24 pb-16 sm:pt-[20vh]" data-step="6">
      <div class="w-full max-w-xl text-center">
        <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-primary">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </div>
        <h2 class="text-3xl font-semibold text-foreground sm:text-4xl">¡Listo!</h2>
        <p class="mt-4 text-lg text-muted-foreground">
          Te avisamos por email cuando abramos acceso para tu estudio.
        </p>
        <p class="mt-2 text-sm text-muted-foreground">
          Mientras tanto, revisa tu inbox — te mandamos una confirmación.
        </p>
        <button
          type="button"
          data-action="close"
          class="mt-8 inline-flex h-11 items-center rounded-md border border-border bg-background px-6 text-sm font-medium text-foreground transition-colors hover:bg-accent"
        >
          Cerrar
        </button>
      </div>
    </div>

    <!-- STEP 7: error -->
    <div class="waitlist-step absolute inset-0 flex items-start justify-center overflow-y-auto px-6 pt-24 pb-16 sm:pt-[20vh]" data-step="7">
      <div class="w-full max-w-xl text-center">
        <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-destructive/10">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-destructive">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </div>
        <h2 class="text-2xl font-semibold text-foreground">No pudimos guardar tus datos</h2>
        <p id="waitlist-error-msg" class="mt-4 text-base text-muted-foreground">
          Intenta de nuevo en unos segundos. Si el problema persiste, escríbenos a hola@clear-book.com
        </p>
        <button
          type="button"
          data-action="retry"
          class="mt-8 inline-flex h-11 items-center rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
        >
          Volver a intentar
        </button>
      </div>
    </div>

  </div>
</div>

<style>
  .waitlist-step {
    opacity: 0;
    pointer-events: none;
    transform: translateY(20px);
  }
  .waitlist-step.active {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
  .waitlist-option.selected {
    border-color: var(--primary);
    background-color: oklch(0.546 0.245 262.881 / 0.08);
  }
  .waitlist-option.selected [data-checkmark] {
    display: block;
  }
  .waitlist-option.selected span:first-child {
    border-color: var(--primary);
    background-color: var(--primary);
    color: var(--primary-foreground);
  }

  /* Lock body scroll while modal is open */
  body.waitlist-open {
    overflow: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    .waitlist-step,
    #waitlist-progress {
      transition: none !important;
    }
  }
</style>

<script define:vars={{ WAITLIST_URL }}>
  // ─────────────────────────────────────────────────────────────
  // State
  // ─────────────────────────────────────────────────────────────
  const TOTAL_STEPS = 5;
  const STEP_SUCCESS = 6;
  const STEP_ERROR = 7;
  const HASH = "#form";

  const state = {
    currentStep: 1,
    data: {
      nombre: "",
      email: "",
      ruc: "",
      clientes: "",
      herramientas: [],
    },
    submitting: false,
  };

  // ─────────────────────────────────────────────────────────────
  // Element refs (cached on init)
  // ─────────────────────────────────────────────────────────────
  let modal, steps, progressBar, closeBtn, backBtn, animeLib;
  let lastFocusedBeforeOpen = null;
  const FOCUSABLE_SELECTOR =
    'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])';

  function getFocusable() {
    if (!modal) return [];
    const active = steps[state.currentStep - 1];
    const scope = active && active.classList.contains("active") ? modal : modal;
    return Array.from(scope.querySelectorAll(FOCUSABLE_SELECTOR)).filter(
      (el) => el.offsetParent !== null && !el.hasAttribute("aria-hidden"),
    );
  }

  function setSiblingsInert(on) {
    // Make everything outside the modal inert + hidden from AT while open.
    const siblings = Array.from(document.body.children).filter((el) => el !== modal);
    for (const el of siblings) {
      if (on) {
        el.setAttribute("inert", "");
        el.setAttribute("aria-hidden", "true");
      } else {
        el.removeAttribute("inert");
        el.removeAttribute("aria-hidden");
      }
    }
  }

  async function init() {
    modal = document.getElementById("waitlist-modal");
    steps = Array.from(document.querySelectorAll(".waitlist-step"));
    progressBar = document.getElementById("waitlist-progress");
    closeBtn = document.getElementById("waitlist-close");
    backBtn = document.getElementById("waitlist-back");
    if (!modal || steps.length === 0) return;

    // Lazy import animejs (only when modal opens)
    try {
      animeLib = await import("animejs");
    } catch (err) {
      console.warn("animejs not available, falling back to CSS transitions", err);
    }

    // Triggers — anything with data-waitlist-trigger
    document.querySelectorAll("[data-waitlist-trigger]").forEach((el) => {
      el.addEventListener("click", (e) => {
        e.preventDefault();
        open();
      });
    });

    window.openWaitlist = open;

    closeBtn.addEventListener("click", close);
    backBtn.addEventListener("click", goBack);

    // Keyboard global
    document.addEventListener("keydown", onKeyDown);

    // Hash-based deeplink: open when URL contains #lista-de-espera
    window.addEventListener("hashchange", syncFromHash);
    syncFromHash();

    // Wire up step buttons
    steps.forEach((step) => {
      const nextBtn = step.querySelector('[data-action="next"]');
      const submitBtn = step.querySelector('[data-action="submit"]');
      const closeAction = step.querySelector('[data-action="close"]');
      const retryBtn = step.querySelector('[data-action="retry"]');
      if (nextBtn) nextBtn.addEventListener("click", advance);
      if (submitBtn) submitBtn.addEventListener("click", submit);
      if (closeAction) closeAction.addEventListener("click", close);
      if (retryBtn) retryBtn.addEventListener("click", () => goTo(5));

      // Option groups
      const optionsGroup = step.querySelector("[data-options]");
      if (optionsGroup) {
        const field = optionsGroup.dataset.options;
        const isMulti = optionsGroup.dataset.multi === "true";
        const optionBtns = optionsGroup.querySelectorAll(".waitlist-option");
        optionBtns.forEach((btn) => {
          btn.addEventListener("click", () => toggleOption(field, btn.dataset.value, isMulti, optionBtns));
        });
      }
    });
  }

  // ─────────────────────────────────────────────────────────────
  // Open / close
  // ─────────────────────────────────────────────────────────────
  function open() {
    if (!modal.classList.contains("hidden")) return;
    lastFocusedBeforeOpen = document.activeElement;
    modal.classList.remove("hidden");
    document.body.classList.add("waitlist-open");
    setSiblingsInert(true);
    goTo(1);
    if (location.hash !== HASH) {
      history.pushState(null, "", HASH);
    }
  }

  function close() {
    if (modal.classList.contains("hidden")) return;
    modal.classList.add("hidden");
    document.body.classList.remove("waitlist-open");
    setSiblingsInert(false);
    if (location.hash === HASH) {
      history.pushState(null, "", location.pathname + location.search);
    }
    // Return focus to the trigger that opened the modal.
    if (lastFocusedBeforeOpen && typeof lastFocusedBeforeOpen.focus === "function") {
      try {
        lastFocusedBeforeOpen.focus();
      } catch {
        // ignore
      }
    }
    lastFocusedBeforeOpen = null;
  }

  function syncFromHash() {
    if (location.hash === HASH) {
      if (modal.classList.contains("hidden")) {
        lastFocusedBeforeOpen = document.activeElement;
        modal.classList.remove("hidden");
        document.body.classList.add("waitlist-open");
        setSiblingsInert(true);
        goTo(1);
      }
    } else if (!modal.classList.contains("hidden")) {
      modal.classList.add("hidden");
      document.body.classList.remove("waitlist-open");
      setSiblingsInert(false);
      if (lastFocusedBeforeOpen && typeof lastFocusedBeforeOpen.focus === "function") {
        try {
          lastFocusedBeforeOpen.focus();
        } catch {
          // ignore
        }
      }
      lastFocusedBeforeOpen = null;
    }
  }

  // ─────────────────────────────────────────────────────────────
  // Navigation
  // ─────────────────────────────────────────────────────────────
  function goTo(stepNum) {
    state.currentStep = stepNum;
    steps.forEach((step) => {
      const n = parseInt(step.dataset.step, 10);
      step.classList.toggle("active", n === stepNum);
    });

    // Animate active step in
    const active = steps[stepNum - 1];
    if (active && animeLib && animeLib.animate) {
      animeLib.animate(active, {
        opacity: [0, 1],
        translateY: [20, 0],
        duration: 400,
        ease: "out(3)",
      });
    }

    // Progress bar (only count real steps 1..TOTAL_STEPS)
    if (stepNum <= TOTAL_STEPS) {
      const pct = ((stepNum - 1) / TOTAL_STEPS) * 100;
      progressBar.style.width = pct + "%";
    } else if (stepNum === STEP_SUCCESS) {
      progressBar.style.width = "100%";
    }

    // Back button: visible only on real steps 2..TOTAL_STEPS
    const showBack = stepNum > 1 && stepNum <= TOTAL_STEPS;
    backBtn.classList.toggle("hidden", !showBack);

    // Auto-focus the first interactive element of the active step.
    setTimeout(() => {
      if (!active) return;
      const input = active.querySelector("input");
      if (input) {
        input.focus();
        return;
      }
      const firstOption = active.querySelector(".waitlist-option");
      if (firstOption) {
        firstOption.focus();
        return;
      }
      const anyBtn = active.querySelector("button");
      if (anyBtn) anyBtn.focus();
    }, 100);
  }

  function advance() {
    if (!validateCurrent()) return;
    if (state.currentStep < TOTAL_STEPS) {
      goTo(state.currentStep + 1);
    } else {
      submit();
    }
  }

  function goBack() {
    // Only allow back navigation on real steps (1..TOTAL_STEPS), not on success/error
    if (state.currentStep > 1 && state.currentStep <= TOTAL_STEPS) {
      // Clear any error on current step before leaving
      const errorEl = steps[state.currentStep - 1].querySelector(".waitlist-error");
      if (errorEl) errorEl.classList.add("hidden");
      goTo(state.currentStep - 1);
    }
  }

  // ─────────────────────────────────────────────────────────────
  // Validation
  // ─────────────────────────────────────────────────────────────
  function validateCurrent() {
    const step = steps[state.currentStep - 1];
    const errorEl = step.querySelector(".waitlist-error");
    const input = step.querySelector("input");
    const optionsGroup = step.querySelector("[data-options]");
    let error = "";

    if (input) {
      const val = input.value.trim();
      const name = input.name;
      if (name === "nombre") {
        if (val.length < 2) error = "Por favor escribe tu nombre completo.";
        else state.data.nombre = val;
      } else if (name === "email") {
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(val)) error = "Email no válido.";
        else state.data.email = val.toLowerCase();
      } else if (name === "ruc") {
        if (!/^(10|15|16|17|20)\d{9}$/.test(val)) {
          error = "RUC debe tener 11 dígitos y empezar con 10, 15, 16, 17 o 20.";
        } else if (!validateRucMod11(val)) {
          error = "RUC inválido (no pasa la verificación SUNAT).";
        } else {
          state.data.ruc = val;
        }
      }
    } else if (optionsGroup) {
      const field = optionsGroup.dataset.options;
      const isMulti = optionsGroup.dataset.multi === "true";
      if (isMulti) {
        if (state.data[field].length === 0) error = "Selecciona al menos una opción.";
      } else {
        if (!state.data[field]) error = "Selecciona una opción.";
      }
    }

    if (error) {
      errorEl.textContent = error;
      errorEl.classList.remove("hidden");
      return false;
    }
    errorEl.classList.add("hidden");
    return true;
  }

  function validateRucMod11(ruc) {
    const weights = [5, 4, 3, 2, 7, 6, 5, 4, 3, 2];
    let sum = 0;
    for (let i = 0; i < 10; i++) sum += parseInt(ruc.charAt(i), 10) * weights[i];
    const expected = (11 - (sum % 11)) % 10;
    return expected === parseInt(ruc.charAt(10), 10);
  }

  // ─────────────────────────────────────────────────────────────
  // Options (single + multi select)
  // ─────────────────────────────────────────────────────────────
  function toggleOption(field, value, isMulti, allBtns) {
    if (isMulti) {
      const idx = state.data[field].indexOf(value);
      if (idx >= 0) state.data[field].splice(idx, 1);
      else state.data[field].push(value);
    } else {
      state.data[field] = value;
    }
    // Re-render selection
    allBtns.forEach((btn) => {
      const v = btn.dataset.value;
      const isSelected = isMulti ? state.data[field].includes(v) : state.data[field] === v;
      btn.classList.toggle("selected", isSelected);
    });
    // Auto-advance on single-select
    if (!isMulti && state.currentStep < TOTAL_STEPS) {
      setTimeout(() => advance(), 250);
    }
  }

  // ─────────────────────────────────────────────────────────────
  // Submit
  // ─────────────────────────────────────────────────────────────
  async function submit() {
    if (state.submitting) return;
    if (!validateCurrent()) return;

    state.submitting = true;
    const submitBtn = steps[TOTAL_STEPS - 1].querySelector('[data-action="submit"]');
    const label = submitBtn.querySelector(".waitlist-submit-label");
    const spinner = submitBtn.querySelector(".waitlist-submit-spinner");
    submitBtn.disabled = true;
    label.textContent = "Enviando...";
    spinner.classList.remove("hidden");

    try {
      const payload = {
        ...state.data,
        userAgent: navigator.userAgent,
        referrer: document.referrer,
      };

      // No Content-Type header → avoids CORS preflight (required by Apps Script)
      const res = await fetch(WAITLIST_URL, {
        method: "POST",
        body: JSON.stringify(payload),
      });
      const json = await res.json();

      if (json.ok) {
        goTo(STEP_SUCCESS);
      } else {
        const msg = (json.errors || []).join(", ") || "Error desconocido";
        goToError("El servidor rechazó los datos: " + msg);
      }
    } catch (err) {
      console.error("Waitlist submit error:", err);
      goToError("No pudimos conectarnos con el servidor. Revisa tu conexión.");
    } finally {
      state.submitting = false;
      submitBtn.disabled = false;
      label.textContent = "Enviar";
      spinner.classList.add("hidden");
    }
  }

  function goToError(msg) {
    document.getElementById("waitlist-error-msg").textContent = msg;
    goTo(STEP_ERROR);
  }

  // ─────────────────────────────────────────────────────────────
  // Keyboard
  // ─────────────────────────────────────────────────────────────
  function onKeyDown(e) {
    if (modal.classList.contains("hidden")) return;
    if (e.key === "Escape") {
      e.preventDefault();
      close();
    } else if (e.key === "Tab") {
      // Focus trap inside the modal.
      const focusables = getFocusable();
      if (focusables.length === 0) {
        e.preventDefault();
        return;
      }
      const first = focusables[0];
      const last = focusables[focusables.length - 1];
      const current = document.activeElement;
      if (e.shiftKey && (current === first || !modal.contains(current))) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && (current === last || !modal.contains(current))) {
        e.preventDefault();
        first.focus();
      }
    } else if (e.key === "Enter") {
      // Don't trigger inside textareas if we add any later
      const target = e.target;
      if (target && target.tagName === "TEXTAREA") return;
      // Shift+Enter → go back
      if (e.shiftKey) {
        e.preventDefault();
        goBack();
        return;
      }
      e.preventDefault();
      if (state.currentStep === TOTAL_STEPS) submit();
      else if (state.currentStep <= TOTAL_STEPS) advance();
    } else {
      // Letter shortcuts on option steps
      const step = steps[state.currentStep - 1];
      const optionsGroup = step?.querySelector("[data-options]");
      if (optionsGroup) {
        const letter = e.key.toUpperCase();
        if (/^[A-H]$/.test(letter)) {
          const allBtns = optionsGroup.querySelectorAll(".waitlist-option");
          const target = Array.from(allBtns).find((btn) => {
            const letterEl = btn.querySelector("span:first-child");
            return letterEl && letterEl.textContent.trim() === letter;
          });
          if (target) {
            e.preventDefault();
            target.click();
          }
        }
      }
    }
  }

  // ─────────────────────────────────────────────────────────────
  // Boot
  // ─────────────────────────────────────────────────────────────
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
  document.addEventListener("astro:after-swap", init);
</script>
