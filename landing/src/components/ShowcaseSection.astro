---
const tabs = [
  {
    id: "notifications",
    label: "Notificaciones",
    iconSvg: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>',
    title: "Buzón Electrónico Unificado",
    description: "Todas las notificaciones SUNAT de tus clientes en un solo lugar. Filtros por empresa, tipo, prioridad y fecha. Nunca más pierdas una notificación importante.",
  },
  {
    id: "vouchers",
    label: "Comprobantes",
    iconSvg: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>',
    title: "CPEs de Compras y Ventas",
    description: "Descarga automática de comprobantes electrónicos. Visualiza, exporta y organiza todos los documentos tributarios sin entrar a SUNAT.",
  },
  {
    id: "analytics",
    label: "Reportes",
    iconSvg: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v16a2 2 0 0 0 2 2h16"/><path d="m19 9-5 5-4-4-3 3"/></svg>',
    title: "Métricas y Análisis",
    description: "Dashboards personalizados para cada empresa. Seguimiento de documentos, alertas vencidas y estado de sincronización en tiempo real.",
  },
];
---

<section id="demo" class="py-16 lg:py-24">
  <div class="container">
    <div class="grid items-start gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Left side - Content -->
      <div class="flex flex-col">
        <div class="animate-fade-in">
          <span class="mb-4 inline-flex items-center rounded-md border bg-secondary px-2.5 py-0.5 text-xs font-semibold text-secondary-foreground">
            Funcionalidades principales
          </span>
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
            Conoce el poder de Clearbook
          </h2>
          <p class="mt-4 max-w-xl text-lg text-muted-foreground">
            Revisa las funcionalidades clave: buzón SUNAT unificado,
            comprobantes automáticos, reportes operativos y seguimiento de
            pendientes por cliente.
          </p>
        </div>

        <!-- Tabs -->
        <div class="animate-fade-in animate-delay-100 mt-8 flex flex-wrap gap-2" role="tablist" aria-label="Funcionalidades">
          {tabs.map((tab, i) => (
            <button
              data-tab={tab.id}
              role="tab"
              aria-selected={i === 0 ? "true" : "false"}
              aria-controls={`panel-${tab.id}`}
              id={`tab-${tab.id}`}
              tabindex={i === 0 ? 0 : -1}
              class={`tab-btn inline-flex h-9 items-center justify-center gap-2 rounded-md px-4 text-sm font-medium transition-colors ${i === 0 ? "bg-primary text-primary-foreground" : "border border-border bg-background text-foreground shadow-xs hover:bg-accent hover:text-accent-foreground dark:border-input dark:bg-input/30 dark:hover:bg-input/50"}`}
            >
              <Fragment set:html={tab.iconSvg} />
              {tab.label}
            </button>
          ))}
        </div>

        <!-- Tab content -->
        {tabs.map((tab, i) => (
          <div data-tab-content={tab.id} role="tabpanel" id={`panel-${tab.id}`} aria-labelledby={`tab-${tab.id}`} class={`animate-fade-in animate-delay-50 mt-8 ${i !== 0 ? "hidden" : ""}`}>
            <h3 class="text-xl font-semibold">{tab.title}</h3>
            <p class="mt-2 text-muted-foreground">{tab.description}</p>
            <button type="button" data-waitlist-trigger class="mt-4 inline-flex cursor-pointer items-center text-sm font-medium text-primary hover:underline">
              Solicitar acceso
              <svg class="ml-1 h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
            </button>
          </div>
        ))}
      </div>

      <!-- Right side - Interactive preview -->
      <div class="animate-fade-in-right animate-delay-200 relative">
        <div class="overflow-hidden rounded-xl border bg-card shadow-xl">
          <!-- Notifications preview -->
          <div data-tab-preview="notifications" class="flex flex-col p-4">
            <div class="mb-4 flex items-center justify-between">
              <span class="text-sm font-medium">Buzón Unificado</span>
              <span class="inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-semibold">23 nuevas</span>
            </div>
            <div class="flex-1 space-y-3">
              {[
                { type: "urgent", company: "Empresa ABC S.A.C.", title: "Requerimiento de Información", time: "Hace 2h" },
                { type: "warning", company: "Comercial XYZ E.I.R.L.", title: "Notificación de Cobranza", time: "Hace 5h" },
                { type: "normal", company: "Servicios 123 S.A.", title: "Constancia de Presentación", time: "Hace 1d" },
              ].map((notif) => (
                <div class="flex items-start gap-3 rounded-lg border bg-background/50 p-3 transition-colors hover:border-primary/30">
                  {notif.type === "urgent" && (
                    <svg class="h-5 w-5 shrink-0 text-destructive" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
                  )}
                  {notif.type === "warning" && (
                    <svg class="h-5 w-5 shrink-0 text-yellow-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  )}
                  {notif.type === "normal" && (
                    <svg class="h-5 w-5 shrink-0 text-green-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                  )}
                  <div class="min-w-0 flex-1">
                    <p class="truncate text-sm font-medium">{notif.title}</p>
                    <p class="text-xs text-muted-foreground">{notif.company}</p>
                  </div>
                  <span class="shrink-0 text-xs text-muted-foreground">{notif.time}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Vouchers preview -->
          <div data-tab-preview="vouchers" class="hidden flex-col p-4">
            <div class="mb-4 flex items-center justify-between">
              <span class="text-sm font-medium">Comprobantes Recibidos</span>
              <span class="inline-flex items-center rounded-md bg-secondary px-2.5 py-0.5 text-xs font-semibold text-secondary-foreground">Febrero 2026</span>
            </div>
            <div class="flex-1 space-y-2">
              <div class="hidden text-xs text-muted-foreground sm:flex sm:gap-4">
                <span class="w-16">Tipo</span>
                <span class="w-20">Número</span>
                <span class="flex-1">RUC Emisor</span>
                <span class="w-24 text-right">Monto</span>
              </div>
              {[
                { type: "F001", number: "00012345", ruc: "20123456789", amount: "S/ 1,250.00" },
                { type: "B001", number: "00054321", ruc: "10987654321", amount: "S/ 350.00" },
                { type: "F002", number: "00009876", ruc: "20111222333", amount: "S/ 4,800.00" },
              ].map((v) => (
                <div class="flex items-center gap-4 rounded-lg border bg-background/50 p-2 text-sm transition-colors hover:border-primary/30">
                  <span class="w-16 font-mono text-xs">{v.type}</span>
                  <span class="w-20 font-mono text-xs">{v.number}</span>
                  <span class="flex-1 truncate text-xs text-muted-foreground">{v.ruc}</span>
                  <span class="w-24 text-right font-medium">{v.amount}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Analytics preview -->
          <div data-tab-preview="analytics" class="hidden flex-col p-4">
            <div class="mb-4 flex items-center justify-between">
              <span class="text-sm font-medium">Resumen del Mes</span>
              <span class="inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-semibold">Febrero 2026</span>
            </div>
            <div class="mb-4 grid grid-cols-2 gap-3">
              <div class="rounded-lg border bg-background/50 p-3">
                <p class="text-2xl font-bold text-primary">47</p>
                <p class="text-xs text-muted-foreground">Notificaciones</p>
              </div>
              <div class="rounded-lg border bg-background/50 p-3">
                <p class="text-2xl font-bold">234</p>
                <p class="text-xs text-muted-foreground">Comprobantes</p>
              </div>
              <div class="rounded-lg border bg-background/50 p-3">
                <p class="text-2xl font-bold text-green-500">12</p>
                <p class="text-xs text-muted-foreground">Empresas activas</p>
              </div>
              <div class="rounded-lg border bg-background/50 p-3">
                <p class="text-2xl font-bold text-yellow-500">3</p>
                <p class="text-xs text-muted-foreground">Pendientes</p>
              </div>
            </div>
            <div class="flex-1 rounded-lg border bg-background/50 p-3">
              <p class="mb-2 text-xs text-muted-foreground">Actividad semanal</p>
              <div class="flex h-20 items-end gap-2">
                <div class="h-2/5 flex-1 rounded-t bg-primary/60"></div>
                <div class="h-[65%] flex-1 rounded-t bg-primary/60"></div>
                <div class="h-[45%] flex-1 rounded-t bg-primary/60"></div>
                <div class="h-4/5 flex-1 rounded-t bg-primary/60"></div>
                <div class="h-3/5 flex-1 rounded-t bg-primary/60"></div>
                <div class="h-[90%] flex-1 rounded-t bg-primary/60"></div>
                <div class="h-3/4 flex-1 rounded-t bg-primary/60"></div>
              </div>
              <div class="mt-1 flex justify-between text-[10px] text-muted-foreground">
                <span>Lun</span><span>Mar</span><span>Mié</span><span>Jue</span><span>Vie</span><span>Sáb</span><span>Dom</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Decorative elements -->
        <div class="absolute -right-4 -top-4 h-32 w-32 rounded-full bg-primary/10 blur-3xl"></div>
        <div class="absolute -bottom-4 -left-4 h-24 w-24 rounded-full bg-primary/5 blur-2xl"></div>
      </div>
    </div>
  </div>
</section>

<script>
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const tabContents = document.querySelectorAll<HTMLElement>('[data-tab-content]');
  const tabPreviews = document.querySelectorAll<HTMLElement>('[data-tab-preview]');

  function activate(tabId: string, focus = false) {
    tabBtns.forEach((b) => {
      const isActive = b.dataset.tab === tabId;
      b.classList.toggle('bg-primary', isActive);
      b.classList.toggle('text-primary-foreground', isActive);
      b.classList.toggle('border', !isActive);
      b.classList.toggle('border-border', !isActive);
      b.classList.toggle('bg-background', !isActive);
      b.classList.toggle('text-foreground', !isActive);
      b.classList.toggle('shadow-xs', !isActive);
      b.classList.toggle('hover:bg-accent', !isActive);
      b.classList.toggle('hover:text-accent-foreground', !isActive);
      b.classList.toggle('dark:border-input', !isActive);
      b.classList.toggle('dark:bg-input/30', !isActive);
      b.classList.toggle('dark:hover:bg-input/50', !isActive);
      b.setAttribute('aria-selected', isActive ? 'true' : 'false');
      b.setAttribute('tabindex', isActive ? '0' : '-1');
      if (isActive && focus) b.focus();
    });

    tabContents.forEach((c) => c.classList.toggle('hidden', c.dataset.tabContent !== tabId));
    tabPreviews.forEach((p) => {
      const isActive = p.dataset.tabPreview === tabId;
      p.classList.toggle('hidden', !isActive);
      p.classList.toggle('flex', isActive);
    });
  }

  tabBtns.forEach((btn, idx) => {
    btn.addEventListener('click', () => {
      const tabId = btn.dataset.tab;
      if (tabId) activate(tabId);
    });

    btn.addEventListener('keydown', (e) => {
      const max = tabBtns.length - 1;
      let target = -1;
      if (e.key === 'ArrowRight') target = idx === max ? 0 : idx + 1;
      else if (e.key === 'ArrowLeft') target = idx === 0 ? max : idx - 1;
      else if (e.key === 'Home') target = 0;
      else if (e.key === 'End') target = max;
      if (target >= 0) {
        e.preventDefault();
        const next = tabBtns[target];
        const id = next.dataset.tab;
        if (id) activate(id, true);
      }
    });
  });
</script>
