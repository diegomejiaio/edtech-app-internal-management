# Public — exposed to the browser (NEXT_PUBLIC_* prefix required by Next.js)
NEXT_PUBLIC_API_URL=http://localhost:7071
NEXT_PUBLIC_API_VERSION=v1
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_ORG_ID=
# Debug auth flow: set to 'true' to enable console logging of JWT payload and Clerk session
NEXT_PUBLIC_DEBUG_AUTH=false
