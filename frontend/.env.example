# API Backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================================
# DEV MODE - Bypasses Clerk authentication
# Set to 'true' for local development without Clerk
# ============================================================
NEXT_PUBLIC_DEV_MODE=true
NEXT_PUBLIC_DEV_TENANT_ID=tnnt-estudios-fuentes
NEXT_PUBLIC_DEV_USER_ID=user_dev_001

# Clerk Authentication (required when DEV_MODE is not 'true')
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# App
NEXT_PUBLIC_APP_VERSION=0.1.0

# AI Assistant (ClearBookAI)
# Set to 'true' to enable the chat bubble
NEXT_PUBLIC_ASSISTANT_ENABLED=false
